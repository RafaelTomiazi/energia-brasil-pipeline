  create view "energia"."public_staging"."stg_aneel_mmgd__dbt_tmp"
    
    
  as (
    -- =====================================================================
-- stg_aneel_mmgd — staging da ANEEL Geração Distribuída
-- =====================================================================
-- Mesmo padrão do stg_ons: 1-pra-1, só renomeia/filtra ruído.
-- =====================================================================

with fonte as (
    select * from "energia"."raw"."aneel_mmgd"
)

select
    -- identificadores
    cod_empreendimento                as id_empreendimento,
    sigla_uf                          as sigla_uf,
    cod_uf_ibge                       as cod_uf_ibge,
    regiao                            as nome_regiao,
    municipio                         as nome_municipio,
    cod_municipio_ibge                as cod_municipio_ibge,

    -- distribuidora
    sigla_agente                      as sigla_distribuidora,
    nome_agente                       as nome_distribuidora,

    -- atributos do empreendimento
    classe_consumo                    as classe_consumo,
    subgrupo_tarifario                as subgrupo_tarifario,
    sigla_tipo_geracao                as sigla_tipo_geracao,
    fonte_geracao                     as fonte_geracao,
    porte                             as porte,
    sigla_modalidade                  as sigla_modalidade,
    modalidade                        as modalidade,
    qtd_uc_recebe_credito             as qtd_uc_recebe_credito,

    -- métricas
    potencia_kw                       as potencia_kw,

    -- geo
    latitude                          as latitude,
    longitude                         as longitude,

    -- temporal
    data_conexao                      as data_conexao,
    ano_conexao                       as ano_conexao,
    mes_conexao                       as mes_conexao,

    -- lineage
    processed_at                      as bronze_processed_at

from fonte
where
    -- Filtros de qualidade
    potencia_kw is not null
    and potencia_kw > 0
    and data_conexao is not null
  );
[0m21:42:47.118841 [debug] [Thread-2 (]: Using postgres connection "model.energia_brasil.stg_ons_geracao_horaria"
[0m21:42:47.120218 [debug] [Thread-2 (]: On model.energia_brasil.stg_ons_geracao_horaria: /* {"app": "dbt", "dbt_version": "1.8.3", "profile_name": "energia_brasil", "target_name": "dev", "node_id": "model.energia_brasil.stg_ons_geracao_horaria"} */

  create view "energia"."public_staging"."stg_ons_geracao_horaria__dbt_tmp"
    
    
  as (
    -- =====================================================================
-- stg_ons_geracao_horaria — staging do ONS
-- =====================================================================
-- Camada staging: 1-pra-1 com a fonte, só padroniza nomes e tipos.
-- Não faz joins. Não agrega. Não inventa coluna.
-- A única "regra" é deixar o dado pronto pra ser usado nos próximos models.
--
-- Materializado como VIEW (config no dbt_project.yml) — sem custo de disco
-- =====================================================================

with fonte as (
    select * from "energia"."raw"."ons_geracao_horaria"
)

select
    -- chaves
    din_instante                      as ts_geracao,
    id_subsistema                     as cod_subsistema,
    nom_subsistema                    as nome_subsistema,
    id_estado                         as sigla_uf,
    nom_estado                        as nome_estado,

    -- atributos da usina
    cod_modalidadeoperacao            as modalidade_operacao,
    nom_tipousina                     as tipo_usina,
    nom_tipocombustivel               as fonte_combustivel,
    nom_usina                         as nome_usina,
    id_ons                            as id_usina,
    ceg                               as ceg,

    -- métricas
    val_geracao                       as geracao_mwh,

    -- flags derivadas (já vieram do Spark)
    eh_renovavel                      as eh_renovavel,
    eh_brasil                         as eh_brasil,

    -- partição como colunas explícitas (vinham implícitas do path)
    ano                               as ano_geracao,
    mes                               as mes_geracao,

    -- lineage
    processed_at                      as bronze_processed_at

from fonte
where
    -- Filtros de qualidade que devem rodar sempre
    val_geracao is not null
    and val_geracao >= 0   -- valores negativos = erro de medição
  );
