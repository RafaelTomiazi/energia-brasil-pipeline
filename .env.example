# ===================================================================
# Variáveis de ambiente — copie este arquivo para .env antes de subir
#   cp .env.example .env
# ===================================================================
# Em produção: TROQUE TODAS as senhas e gere um Fernet key novo.
# Em dev local: pode rodar com os valores default. Tudo funciona.
# ===================================================================

# AIRFLOW_UID — id do usuário Linux dentro dos containers do Airflow.
# Em Linux/Mac, rode "id -u" e use o resultado. Em Windows, deixe 50000.
AIRFLOW_UID=50000
